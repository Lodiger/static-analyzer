<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <Label text="Справка: Статистический анализатор"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-padding: 14 14 6 14;"/>
    </top>

    <center>
        <TabPane>

            <Tab text="Формулы" closable="false">
                <ScrollPane fitToWidth="true">
                    <TextArea editable="false" wrapText="true" prefHeight="480"
                              style="-fx-font-family: monospace; -fx-font-size: 12;"
                              text="══════════════════════════════════════════════════════&#10;ФОРМУЛЫ СТАТИСТИЧЕСКИХ ПОКАЗАТЕЛЕЙ&#10;══════════════════════════════════════════════════════&#10;&#10;n     — количество наблюдений&#10;xi    — i-е значение&#10;&#10;─── Среднее (математическое ожидание) ────────────────&#10;μ = (1/n) · Σxi&#10;&#10;─── Медиана ──────────────────────────────────────────&#10;Середина упорядоченного ряда.&#10;Чётное n: (x[n/2] + x[n/2+1]) / 2&#10;Нечётное n: x[(n+1)/2]&#10;&#10;─── Дисперсия (несмещённая) ──────────────────────────&#10;s² = Σ(xi - μ)² / (n - 1)&#10;&#10;─── Стандартное отклонение ───────────────────────────&#10;σ = √s²&#10;&#10;─── Квартили (линейная интерполяция) ─────────────────&#10;Q1 = percentile(25%), Q3 = percentile(75%)&#10;МКР (IQR) = Q3 - Q1&#10;&#10;─── Асимметрия (Skewness, Фишер g1) ─────────────────&#10;g1 = n / ((n-1)(n-2)) · Σ[(xi - μ)³ / s³]&#10;&#10;   g1 &gt; 0 → правосторонняя (хвост вправо)&#10;   g1 &lt; 0 → левосторонняя  (хвост влево)&#10;   |g1| &lt; 0.5 → приблизительно симметрично&#10;&#10;─── Эксцесс (Kurtosis, Фишер g2, избыточный) ────────&#10;g2 = n(n+1) / ((n-1)(n-2)(n-3)) · Σ[(xi-μ)⁴/s⁴]&#10;     - 3(n-1)² / ((n-2)(n-3))&#10;&#10;   g2 = 0  → нормальное распределение&#10;   g2 &gt; 0  → лептокуртическое (острый пик)&#10;   g2 &lt; 0  → платикуртическое (плоский пик)&#10;&#10;─── Коэффициент вариации ─────────────────────────────&#10;CV = (σ / |μ|) · 100%&#10;&#10;   CV &lt; 10% → однородность высокая&#10;   10-25%  → умеренная&#10;   &gt; 25%   → сильный разброс&#10;&#10;─── Кривая нормального распределения (PDF) ───────────&#10;f(x) = 1 / (σ√(2π)) · exp(-(x-μ)² / (2σ²))&#10;&#10;Масштаб для наложения на гистограмму частот:&#10;  y_scaled = f(x) · n · binWidth&#10;&#10;─── Правило Стёрджесса (число интервалов) ────────────&#10;k = 1 + log₂(n) = 1 + 3.322 · lg(n)"/>
                </ScrollPane>
            </Tab>

            <Tab text="Инструкция" closable="false">
                <ScrollPane fitToWidth="true">
                    <TextArea editable="false" wrapText="true" prefHeight="480"
                              style="-fx-font-family: sans-serif; -fx-font-size: 12;"
                              text="══════════════════════════════════════════════════════&#10;ИНСТРУКЦИЯ ПОЛЬЗОВАТЕЛЯ&#10;══════════════════════════════════════════════════════&#10;&#10;1. ЗАГРУЗКА ФАЙЛА&#10;   Меню «Файл → Открыть файл» или кнопка «Открыть».&#10;   Поддерживаемые форматы: .csv, .xlsx, .xls&#10;   • CSV: первая строка — заголовки, разделитель , или ;&#10;   • Excel: первый лист, первая строка — заголовки&#10;&#10;2. ВЫБОР КОЛОНОК&#10;   Отметьте флажками нужные колонки в левой панели.&#10;   «Все» / «Снять» — выбор/снятие всех колонок.&#10;   Анализируются только числовые колонки.&#10;   Нечисловые строки пропускаются автоматически.&#10;&#10;3. НАСТРОЙКА ПАРАМЕТРОВ&#10;   • Интервалов (bins): число столбцов гистограммы (2–200)&#10;     По умолчанию — 10. Правило Стёрджесса: 1 + log₂(n)&#10;   • IQR-множитель: граница выбросов (обычно 1.5 или 3.0)&#10;   • Кривая нормального распределения: наложение PDF&#10;   • Сетка: горизонтальные линии на гистограмме&#10;&#10;4. ЗАПУСК АНАЛИЗА&#10;   Кнопка «▶ Запустить анализ» или F5.&#10;   Конвейер обрабатывает каждую выбранную колонку:&#10;   Валидация → Парсинг → Сортировка → Статистика → Гистограмма&#10;&#10;5. ПРОСМОТР РЕЗУЛЬТАТОВ&#10;   • Вкладка «Гистограмма» — визуализация&#10;   • Вкладка «Статистика»  — таблица метрик&#10;   • ComboBox вверху — переключение между колонками&#10;   • Журнал конвейера — подробный лог выполнения&#10;&#10;6. СОХРАНЕНИЕ РЕЗУЛЬТАТОВ&#10;   Меню «Анализ» или кнопки в панели инструментов:&#10;   Форматы графика:  PNG, SVG, PDF, HTML (Chart.js)&#10;   Форматы таблицы: CSV, XLSX, JSON, Markdown&#10;&#10;7. КОНФИГУРАЦИЯ&#10;   «Файл → Сохранить конфигурацию» — сохранить в JSON&#10;   «Файл → Загрузить конфигурацию» — загрузить JSON&#10;   Конфиг хранит: bins, IQR, флаги отображения&#10;&#10;8. ОШИБКИ&#10;   • «Недостаточно данных» — менее 3 числовых значений&#10;   • «Файл пуст» — загружен пустой файл&#10;   • «Неверный формат» — не CSV/XLSX&#10;   Все ошибки отображаются в журнале конвейера."/>
                </ScrollPane>
            </Tab>

            <Tab text="О программе" closable="false">
                <VBox spacing="12" style="-fx-padding: 20;">
                    <Label text="Статистический анализатор" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    <Label text="Версия 1.0 | Java 17 + JavaFX 21" style="-fx-text-fill: #666;"/>
                    <Separator/>
                    <Label text="Паттерн: «Каналы и фильтры» (Pipes and Filters)" wrapText="true"/>
                    <Label text="Вариант: Анализ распределения" wrapText="true"/>
                    <Separator/>
                    <Label text="Конвейер обработки:" style="-fx-font-weight: bold;"/>
                    <TextArea editable="false" prefHeight="120" wrapText="true"
                              style="-fx-font-family: monospace; -fx-font-size: 11;"
                              text="Ввод → ValidationFilter → ParseFilter → SortFilter&#10;       → StatCalcFilter → HistogramFilter → StatResult&#10;&#10;ExportFilter (отдельно) → PNG | SVG | PDF | HTML&#10;                        → CSV | XLSX | JSON | Markdown"/>
                    <Separator/>
                    <Label text="Зависимости: Apache POI, OpenCSV, Jackson, PDFBox" wrapText="true"
                           style="-fx-text-fill: #555;"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>

    <bottom>
        <Label text="F1 — эта справка | F5 — запуск конвейера | Ctrl+O — открыть файл"
               style="-fx-padding: 6 14; -fx-text-fill: #888; -fx-font-size: 11;"/>
    </bottom>

</BorderPane>
