<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.statanalyzer.controller.StatController"
            stylesheets="@styles.css">

    <!-- ═══ МЕНЮ ══════════════════════════════════════════════════════════ -->
    <top>
        <VBox>
            <MenuBar>
                <Menu text="Файл">
                    <MenuItem text="Открыть файл..." onAction="#handleOpenFile" accelerator="Ctrl+O"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Сохранить конфигурацию..." onAction="#handleSaveConfig"/>
                    <MenuItem text="Загрузить конфигурацию..." onAction="#handleLoadConfig"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Выход" onAction="#handleExit" accelerator="Alt+F4"/>
                </Menu>
                <Menu text="Анализ">
                    <MenuItem text="Запустить конвейер" onAction="#handleRunPipeline" accelerator="F5"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Сохранить график..." onAction="#handleSaveChart"/>
                    <MenuItem text="Сохранить таблицу..." onAction="#handleSaveTable"/>
                </Menu>
                <Menu text="Справка">
                    <MenuItem text="Формулы и инструкция" onAction="#handleShowHelp" accelerator="F1"/>
                </Menu>
            </MenuBar>

            <!-- Строка инструментов -->
            <ToolBar>
                <Button text="📂 Открыть" onAction="#handleOpenFile" styleClass="toolbar-button"/>
                <Separator/>
                <Button text="▶ Запустить" onAction="#handleRunPipeline" fx:id="runButton"
                        styleClass="toolbar-button, run-button"/>
                <Separator/>
                <Button text="💾 Сохранить график" onAction="#handleSaveChart" styleClass="toolbar-button"/>
                <Button text="📋 Сохранить таблицу" onAction="#handleSaveTable" styleClass="toolbar-button"/>
                <Separator/>
                <ProgressIndicator fx:id="progressIndicator" prefWidth="24" prefHeight="24"/>
                <Label fx:id="statusLabel" styleClass="status-label" maxWidth="Infinity"
                       HBox.hgrow="ALWAYS" text="Загрузите файл .csv или .xlsx"/>
            </ToolBar>
        </VBox>
    </top>

    <!-- ═══ ЛЕВАЯ ПАНЕЛЬ (НАСТРОЙКИ) ══════════════════════════════════════ -->
    <left>
        <ScrollPane fitToWidth="true" prefWidth="260" styleClass="sidebar">
            <VBox spacing="8" style="-fx-padding: 10;">

                <!-- Информация о файле -->
                <TitledPane text="Файл" collapsible="false" styleClass="section-title">
                    <VBox spacing="4">
                        <Label fx:id="fileInfoLabel" text="Файл не выбран" wrapText="true"
                               styleClass="file-info"/>
                        <Button text="Открыть файл..." onAction="#handleOpenFile"
                                maxWidth="Infinity" styleClass="action-button"/>
                    </VBox>
                </TitledPane>

                <!-- Выбор колонок -->
                <TitledPane text="Колонки для анализа" collapsible="false" styleClass="section-title">
                    <VBox spacing="4">
                        <Label fx:id="columnCountLabel" text="0 колонок" styleClass="hint-label"/>
                        <ListView fx:id="columnListView" prefHeight="180" styleClass="column-list"/>
                        <HBox spacing="4">
                            <Button text="Все" onAction="#handleSelectAll"
                                    maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="Снять" onAction="#handleDeselectAll"
                                    maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>
                </TitledPane>

                <!-- Параметры анализа -->
                <TitledPane text="Параметры" collapsible="false" styleClass="section-title">
                    <GridPane hgap="8" vgap="6">
                        <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="110"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Интервалов (bins):" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Spinner fx:id="numBinsSpinner" editable="true"
                                 GridPane.columnIndex="1" GridPane.rowIndex="0"
                                 maxWidth="80"/>

                        <Label text="IQR-множитель:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Spinner fx:id="iqrSpinner" editable="true"
                                 GridPane.columnIndex="1" GridPane.rowIndex="1"
                                 maxWidth="80"/>
                    </GridPane>
                </TitledPane>

                <!-- Флаги отображения -->
                <TitledPane text="Отображение" collapsible="false" styleClass="section-title">
                    <VBox spacing="4">
                        <CheckBox fx:id="showNormalCurveCheck" text="Кривая нормального распределения"
                                  selected="true"/>
                        <CheckBox fx:id="showOutliersCheck" text="Выбросы (IQR-метод)" selected="false"/>
                        <CheckBox fx:id="showGridCheck" text="Сетка" selected="true"/>
                    </VBox>
                </TitledPane>

                <!-- Кнопка запуска -->
                <Button text="▶ Запустить анализ" onAction="#handleRunPipeline"
                        maxWidth="Infinity" styleClass="big-run-button"/>

            </VBox>
        </ScrollPane>
    </left>

    <!-- ═══ ЦЕНТР (РЕЗУЛЬТАТЫ) ════════════════════════════════════════════ -->
    <center>
        <VBox spacing="0">

            <!-- Выбор колонки для просмотра -->
            <HBox spacing="8" style="-fx-padding: 6 10 4 10; -fx-background-color: #f5f5f5;">
                <Label text="Просмотр колонки:"/>
                <ComboBox fx:id="columnSelector" prefWidth="200"/>
            </HBox>

            <!-- Вкладки: гистограмма / таблица -->
            <TabPane VBox.vgrow="ALWAYS">

                <!-- Вкладка: Гистограмма -->
                <Tab text="Гистограмма" closable="false">
                    <ScrollPane fitToWidth="true" fitToHeight="true">
                        <Canvas fx:id="histogramCanvas" width="860" height="480"/>
                    </ScrollPane>
                </Tab>

                <!-- Вкладка: Статистика -->
                <Tab text="Статистика" closable="false">
                    <TableView fx:id="statsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="metricColumn" text="Показатель" prefWidth="280"/>
                            <TableColumn fx:id="valueColumn"  text="Значение"   prefWidth="180"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </Tab>

            </TabPane>

            <!-- Журнал конвейера -->
            <TitledPane text="Журнал конвейера" prefHeight="140" style="-fx-min-height: 100;">
                <TextArea fx:id="pipelineLogArea" editable="false" wrapText="false"
                          style="-fx-font-family: monospace; -fx-font-size: 11; -fx-background-color: #1e1e1e; -fx-text-fill: #d4d4d4;"/>
            </TitledPane>
        </VBox>
    </center>

</BorderPane>
